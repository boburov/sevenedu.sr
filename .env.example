# ─────────── Database ───────────
DATABASE_URL=postgresql://user:password@localhost:5432/sevenedu

# ─────────── JWT ───────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=24h

# ─────────── Admin Panel Login ───────────
# Admin panelga kirish uchun login/parol (oddiy matn, hash emas)
ADMIN_EMAIL=admin@sevenedu.org
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Admin
ADMIN_SURNAME=User
ADMIN_ROLE=SUPER_ADMIN

# ─────────── Frontend URLs ───────────
FRONTEND_URL=https://sevenedu.org
FRONTEND_ORIGIN=https://sevenedu.org

# ─────────── Lokal (VPS) fayl yuklash ───────────
# Yangi pfp / kurs thumbnaillari shu yerga saqlanib, /uploads orqali beriladi.
# PUBLIC_BASE_URL — server ochiq turgan domen (eski S3 URL'lar kabi absolyut URL hosil qilish uchun).
PUBLIC_BASE_URL=https://api.sevenedu.org
# UPLOAD_DIR — fayllar saqlanadigan papka (bo'sh bo'lsa: <server>/uploads).
UPLOAD_DIR=

# ─────────── Email (Nodemailer) ───────────
EMAIL_USER=your-smtp-user@gmail.com
EMAIL_PASS=your-smtp-app-password

# ─────────── OpenAI ───────────
OPENAI_API_KEY=sk-...

# ─────────── AWS S3 (eski bucket) ───────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ─────────── AWS S3 (yangi bucket) ───────────
NEW_AWS_ACCESS_KEY_ID=
NEW_AWS_SECRET_ACCESS_KEY=
NEW_AWS_BUCKET_NAME=

# ─────────── Firebase Admin SDK ───────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─────────── Vimeo (offline download + admin upload) ───────────
# Pro/Business/Premium Personal Access Token.
# Scopes: public + private + video_files + upload + edit
#   (upload + edit — admin paneldan video yuklash uchun MAJBURIY)
# Token: https://developer.vimeo.com/apps → app → Authentication → Generate access token
VIMEO_ACCESS_TOKEN=

# ─────────── Google OAuth ───────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Web client ID used as `serverClientId` by the Flutter app (google_sign_in).
# Mobile ID token `aud` is validated against this value.
GOOGLE_MOBILE_CLIENT_ID=496654947492-m717p6v03d4k03r3r9b4sp30jkt0m2hp.apps.googleusercontent.com

# ─────────── Apple Sign-In (ixtiyoriy) ───────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_CALLBACK_URL=

# Do'kon (shop) mahsulot rasmlari Telegram guruhda saqlanadi
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
