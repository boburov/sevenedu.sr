# ─────────── Database ───────────
DATABASE_URL=postgresql://user:password@localhost:5432/sevenedu

# ─────────── JWT ───────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=24h

# ─────────── Admin Panel Login ───────────
# Admin panelga kirish uchun login/parol (oddiy matn, hash emas)
ADMIN_EMAIL=admin@sevenedu.org
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Admin
ADMIN_SURNAME=User
ADMIN_ROLE=SUPER_ADMIN

# ─────────── Frontend URLs ───────────
FRONTEND_URL=https://sevenedu.org
FRONTEND_ORIGIN=https://sevenedu.org

# ─────────── Email (Nodemailer) ───────────
EMAIL_USER=your-smtp-user@gmail.com
EMAIL_PASS=your-smtp-app-password

# ─────────── OpenAI ───────────
OPENAI_API_KEY=sk-...

# ─────────── AWS S3 (eski bucket) ───────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ─────────── AWS S3 (yangi bucket) ───────────
NEW_AWS_ACCESS_KEY_ID=
NEW_AWS_SECRET_ACCESS_KEY=
NEW_AWS_BUCKET_NAME=

# ─────────── Firebase Admin SDK ───────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─────────── Google OAuth ───────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────── Apple Sign-In (ixtiyoriy) ───────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_CALLBACK_URL=
